          "audio_duration": 8.16
        },
        {
          "segment_id": "segment-02",
          "text": "它更像一个统一阅读收件箱，强项是保存、标注和稍后阅读。",
          "kind": "inference",
          "attribution": "AI",
          "source_refs": [
            {
              "source_id": "source-reader",
