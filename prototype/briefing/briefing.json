      "item_id": "item-001",
      "title": "Particle 已把新闻摘要做成连续音频队列",
      "content_type": "product",
      "event_cluster_id": "particle-audio-queue",
      "source_ids": [
        "source-particle"
      ],
      "essence": "Particle 把多来源新闻摘要和 Audio Queue 放进同一个消费流程。",
      "spoken_segments": [
        {
          "segment_id": "segment-01",
          "text": "第一条。Particle 已经把多来源新闻摘要和连续音频队列放进同一个产品。",
          "kind": "fact",
          "attribution": "source",
          "source_refs": [
            {
              "source_id": "source-particle",
              "label": "官方产品页 · Audio queue",
              "anchor_kind": "paragraph",
              "locator": "Audio queue",
              "url": "https://particle.news/android"
            }
          ],
          "audio_file": "audio/item-001-segment-01.mp3",
          "audio_duration": 7.392
        },
        {
          "segment_id": "segment-02",
          "text": "它证明用户愿意用听的方式快速消费一批新闻，而不是逐篇打开。",
          "kind": "inference",
          "attribution": "AI",
          "source_refs": [
            {
              "source_id": "source-particle",
              "label": "官方产品页 · 产品形态",
              "anchor_kind": "paragraph",
              "locator": "For You / Audio queue",
              "url": "https://particle.news/android"
            }
          ],
          "audio_file": "audio/item-001-segment-02.mp3",
          "audio_duration": 6.288
        },
        {
          "segment_id": "segment-03",
          "text": "但它主要处理平台聚合的公共新闻，并不是用户自己的邮件、文件和任意内容收件箱。",
          "kind": "inference",
          "attribution": "AI",
          "source_refs": [
            {
              "source_id": "source-particle",
              "label": "官方产品页 · 输入边界",
              "anchor_kind": "paragraph",
              "locator": "Personalized news",
              "url": "https://particle.news/android"
            }
          ],
          "audio_file": "audio/item-001-segment-03.mp3",
          "audio_duration": 7.656
        }
      ],
      "why_it_matters": "最接近目标消费体验，但个人多源投递仍是空白。",
      "caveats": [
        "产品页不能证明其内部摘要准确率"
      ],
      "suggested_action": "save",
      "action_reason": "保留为连续音频交互基线。",
      "course_url": null
    },
