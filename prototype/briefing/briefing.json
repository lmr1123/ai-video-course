            }
          ],
          "audio_file": "audio/item-003-segment-01.mp3",
          "audio_duration": 7.56
        },
        {
          "segment_id": "segment-02",
          "text": "它的优势是回答和归纳基于用户提供的来源，并能回到相关引用。",
          "kind": "fact",
          "attribution": "source",
          "source_refs": [
            {
              "source_id": "source-notebooklm",
              "label": "Google 官方博客 · 来源引用",
              "anchor_kind": "paragraph",
              "locator": "inline citations",
              "url": "https://blog.google/innovation-and-ai/products/notebooklm-audio-video-sources/"
            }
          ],
          "audio_file": "audio/item-003-segment-02.mp3",
          "audio_duration": 6.096
        },
        {
          "segment_id": "segment-03",
          "text": "但多个来源通常会被合成为一个 Audio Overview，不天然保留每条资讯的独立决策动作。",
          "kind": "inference",
          "attribution": "AI",
          "source_refs": [
            {
              "source_id": "source-notebooklm",
              "label": "Google 官方博客 · Audio Overview",
              "anchor_kind": "paragraph",
              "locator": "Audio Overview",
              "url": "https://blog.google/innovation-and-ai/products/notebooklm-audio-video-sources/"
            }
          ],
          "audio_file": "audio/item-003-segment-03.mp3",
          "audio_duration": 7.584
        }
      ],
      "why_it_matters": "来源约束和引用是可信提炼的直接基线。",
      "caveats": [
        "音频中的每一句是否绑定细粒度引用，官方页面没有明确承诺"
      ],
      "suggested_action": "open",
      "action_reason": "进一步比较引用交互。",
      "course_url": null
    },
